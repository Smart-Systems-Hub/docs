            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"@context\": [\r\n    \"https://w3id.org/tractusx/edc/v0.0.1\",\r\n    \"http://www.w3.org/ns/odrl.jsonld\",\r\n    {\r\n      \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\r\n    }\r\n  ],\r\n  \"@type\": \"PolicyDefinition\",\r\n  \"@id\": \"{{access-policy}}\",\r\n  \"policy\": {\r\n    \"@type\": \"Set\"\r\n  }\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{provider-connector-url}}/management/v3/policydefinitions",
