            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "password",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"@context\": [\r\n    \"https://w3id.org/factoryx/policy/v1.0.0\",\r\n    \"http://www.w3.org/ns/odrl.jsonld\",\r\n    {\r\n      \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\r\n    }\r\n  ],\r\n  \"@type\": \"PolicyDefinition\",\r\n  \"@id\": \"initial-check-access-policy\",\r\n  \"policy\": {\r\n    \"@type\": \"Set\",\r\n    \"permission\": [\r\n      {\r\n        \"action\": \"use\",\r\n        \"constraint\": {\r\n          \"leftOperand\": \"BusinessPartnerDID\",\r\n          \"operator\": \"eq\",\r\n          \"rightOperand\": \"did:web:dim-static-prod.dis-cloud-prod.cfapps.eu10-004.hana.ondemand.com:dim-hosted:376f8182-8590-46d8-9929-219417e71420:ssh-internal-test-entity-6-identity\"\r\n        }\r\n      }\r\n    ]\r\n  }\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://fx-provider-connector.c-27d7c36.kyma.ondemand.com/management/v3/policydefinitions",
              "protocol": "https",
              "host": [
                "fx-provider-connector",
                "c-27d7c36",
                "kyma",
                "ondemand",
                "com"
              ],
              "path": [
                "management",
