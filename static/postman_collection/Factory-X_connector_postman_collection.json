        {
          "name": "Create contract definition",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{provider-connector-x-api-key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"@context\": {\r\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\r\n  },\r\n  \"@type\": \"ContractDefinition\",\r\n  \"@id\": \"{{contract-definition}}\",\r\n  \"accessPolicyId\": \"{{access-policy}}\",\r\n  \"contractPolicyId\": \"{{usage-policy}}\",\r\n  \"assetsSelector\": \r\n    {\r\n      \"@type\": \"CriterionDto\",\r\n      \"operandLeft\": \"https://w3id.org/edc/v0.0.1/ns/id\",\r\n      \"operator\": \"=\",\r\n      \"operandRight\": \"{{asset-id}}\"\r\n    }\r\n  \r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{provider-connector-url}}/management/v3/contractdefinitions",
              "host": [
                "{{provider-connector-url}}"
              ],
              "path": [
                "management",
                "v3",
                "contractdefinitions"
              ]
            }
          },
          "response": []
        }
