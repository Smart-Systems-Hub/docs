            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"@context\": [\r\n        \"https://w3id.org/tractusx/policy/v1.0.0\",\r\n        \"http://www.w3.org/ns/odrl.jsonld\",\r\n        {\r\n            \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\",\r\n            \"fx-policy\": \"https://w3id.org/factoryx/policy/\"\r\n        }\r\n    ],\r\n    \"@type\": \"ContractRequest\",\r\n    \"counterPartyAddress\": \"{{provider-connector-dsp-url}}/api/v1/dsp\",\r\n    \"protocol\": \"{SUPPORTED_TYPE}\",\r\n    \"policy\": {\r\n        \"@id\": \"{OFFER_ID}\",\r\n        \"@type\": \"Offer\",\r\n        \"assigner\": \"{{provider-connector-did}}\",\r\n        \"permission\": [\r\n            {\r\n                \"action\": \"use\",\r\n                \"constraint\": {\r\n                        \"leftOperand\": \"fx-policy:BusinessPartnerDID\",\r\n                        \"operator\": \"eq\",\r\n                        \"rightOperand\": \"{{consumer-connector-did}}\"\r\n                }\r\n            }\r\n        ],\r\n        \"prohibition\": [],\r\n        \"obligation\": [],\r\n        \"target\": \"{{asset-id}}\"\r\n    },\r\n    \"callbackAddresses\": []\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{consumer-connector-url}}/management/v3/edrs",
              "host": [
                "{{consumer-connector-url}}"
