  "item": [
    {
      "name": "Provider",
      "item": [
        {
          "name": "Create asset",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{provider-connector-x-api-key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"@context\": {},\r\n  \"@type\": \"Asset\",\r\n  \"@id\": \"{{asset-id}}\",\r\n  \"properties\": {\r\n    \"description\": \"{DESCRIPTION_FOR_ASSET}\"\r\n  },\r\n  \"dataAddress\": {\r\n    \"@type\": \"DataAddress\",\r\n    \"type\": \"{SUPPORTED_TYPE}\",\r\n    \"baseUrl\": \"{API_PUBLIC_URL}\"\r\n  }\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{provider-connector-url}}/management/v3/assets",
              "host": [
                "{{provider-connector-url}}"
              ],
              "path": [
                "management",
                "v3",
                "assets"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create access policy",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{provider-connector-x-api-key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"@context\": [\r\n    \"https://w3id.org/tractusx/edc/v0.0.1\",\r\n    \"http://www.w3.org/ns/odrl.jsonld\",\r\n    {\r\n      \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\r\n    }\r\n  ],\r\n  \"@type\": \"PolicyDefinition\",\r\n  \"@id\": \"{{access-policy}}\",\r\n  \"policy\": {\r\n    \"@type\": \"Set\"\r\n  }\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{provider-connector-url}}/management/v3/policydefinitions",
              "host": [
                "{{provider-connector-url}}"
              ],
              "path": [
                "management",
                "v3",
                "policydefinitions"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create usage policy",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{provider-connector-x-api-key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"@context\": [\r\n    \"https://w3id.org/tractusx/edc/v0.0.1\",\r\n    \"http://www.w3.org/ns/odrl.jsonld\",\r\n    {\r\n      \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\r\n    }\r\n  ],\r\n  \"@type\": \"PolicyDefinition\",\r\n  \"@id\": \"{{usage-policy}}\",\r\n  \"policy\": {\r\n    \"@type\": \"Set\",\r\n    \"permission\": [\r\n      {\r\n        \"action\": \"use\",\r\n        \"constraint\": {\r\n          \"leftOperand\": \"BusinessPartnerNumber\",\r\n          \"operator\": \"eq\",\r\n          \"rightOperand\": \"{{consumer-connector-bpn}}\"\r\n        }\r\n      }\r\n    ]\r\n  }\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{provider-connector-url}}/management/v3/policydefinitions",
              "host": [
                "{{provider-connector-url}}"
              ],
              "path": [
                "management",
                "v3",
                "policydefinitions"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create contract definition",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{provider-connector-x-api-key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"@context\": {},\r\n  \"@id\": \"{{contract-definition}}\",\r\n  \"@type\": \"ContractDefinition\",\r\n  \"accessPolicyId\": \"{{access-policy}}\",\r\n  \"contractPolicyId\": \"{{usage-policy}}\",\r\n  \"assetsSelector\": {\r\n    \"@type\": \"CriterionDto\",\r\n    \"operandLeft\": \"https://w3id.org/edc/v0.0.1/ns/id\",\r\n    \"operator\": \"=\",\r\n    \"operandRight\": \"{{asset-id}}\"\r\n  }\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{provider-connector-url}}/management/v3/contractdefinitions",
              "host": [
                "{{provider-connector-url}}"
              ],
              "path": [
                "management",
                "v3",
                "contractdefinitions"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Consumer",
      "item": [
        {
          "name": "Catalog request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{consumer-connector-x-api-key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"@context\": {\r\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\r\n  },\r\n  \"protocol\": \"dataspace-protocol-http\",\r\n  \"counterPartyAddress\": \"{{provider-connector-dsp-url}}/api/v1/dsp\",\r\n  \"counterPartyId\": \"{{provider-connector-bpn}}\",\r\n  \"querySpec\": {\r\n    \"offset\": 0,\r\n    \"limit\": 50\r\n  }\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{consumer-connector-url}}/management/v3/catalog/request",
              "host": [
                "{{consumer-connector-url}}"
              ],
              "path": [
                "management",
                "v3",
                "catalog",
                "request"
              ]
            }
          },
          "response": []
        },
        {
          "name": "EDRs",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{consumer-connector-x-api-key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"@context\": [\r\n    \"https://w3id.org/tractusx/policy/v1.0.0\",\r\n    \"http://www.w3.org/ns/odrl.jsonld\",\r\n    {\r\n      \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\",\r\n      \"tx\": \"https://w3id.org/tractusx/v0.0.1/ns/\"\r\n    }\r\n  ],\r\n  \"@type\": \"ContractRequest\",\r\n  \"counterPartyAddress\": \"{{provider-connector-dsp-url}}/api/v1/dsp\",\r\n  \"protocol\": \"{SUPPORTED_TYPE}\",\r\n  \"policy\": {\r\n    \"@id\": \"{OFFER_ID}\",\r\n    \"@type\": \"Offer\",\r\n    \"assigner\": \"{{provider-connector-bpn}}\",\r\n    \"permission\": [\r\n      {\r\n        \"action\": \"use\",\r\n        \"constraint\": {\r\n          \"leftOperand\": \"tx:BusinessPartnerNumber\",\r\n          \"operator\": \"eq\",\r\n          \"rightOperand\": \"{{consumer-connector-bpn}}\"\r\n        }\r\n      }\r\n    ],\r\n    \"prohibition\": [],\r\n    \"obligation\": [],\r\n    \"target\": \"{{asset-id}}\"\r\n  },\r\n  \"callbackAddresses\": []\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{consumer-connector-url}}/management/v3/edrs",
              "host": [
                "{{consumer-connector-url}}"
              ],
              "path": [
                "management",
                "v3",
                "edrs"
              ]
            }
          },
          "response": []
        },
        {
          "name": "EDRs request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{consumer-connector-x-api-key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"@context\": {\r\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\r\n  },\r\n  \"@type\": \"QuerySpec\",\r\n  \"filterExpression\": [\r\n    {\r\n      \"operandLeft\": \"assetId\",\r\n      \"operator\": \"=\",\r\n      \"operandRight\": \"{{asset-id}}\"\r\n    }\r\n  ]\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{consumer-connector-url}}/management/v3/edrs/request",
              "host": [
                "{{consumer-connector-url}}"
              ],
              "path": [
                "management",
                "v3",
                "edrs",
                "request"
              ]
            }
          },
          "response": []
        },
