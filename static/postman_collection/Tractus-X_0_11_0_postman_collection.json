  "item": [
    {
      "name": "Provider",
      "item": [
        {
          "name": "Create asset",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{provider-connector-x-api-key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"@context\": {},\r\n  \"@type\": \"Asset\",\r\n  \"@id\": \"{{asset-id}}\",\r\n  \"properties\": {\r\n    \"description\": \"{DESCRIPTION_FOR_ASSET}\"\r\n  },\r\n  \"dataAddress\": {\r\n    \"@type\": \"DataAddress\",\r\n    \"type\": \"{SUPPORTED_TYPE}\",\r\n    \"baseUrl\": \"{API_PUBLIC_URL}\"\r\n  }\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{provider-connector-url}}/management/v3/assets",
              "host": [
                "{{provider-connector-url}}"
              ],
              "path": [
                "management",
                "v3",
                "assets"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Access Policy",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{provider-connector-x-api-key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"@context\": [\r\n        \"https://w3id.org/catenax/2025/9/policy/odrl.jsonld\",\r\n        \"https://w3id.org/catenax/2025/9/policy/context.jsonld\",\r\n        {\r\n            \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\r\n        }\r\n    ],\r\n    \"@type\": \"PolicyDefinition\",\r\n    \"@id\": \"{{access-policy}}\",\r\n    \"policy\": {\r\n        \"@type\": \"Set\",\r\n        \"permission\": [\r\n            {\r\n                \"action\": \"access\",\r\n                \"constraint\": {\r\n                    \"leftOperand\": \"BusinessPartnerNumber\",\r\n                    \"operator\": \"isAnyOf\",\r\n                    \"rightOperand\": \"{{consumer-connector-bpn}}\"\r\n                }\r\n            }\r\n        ]\r\n    }\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{provider-connector-url}}/management/v3/policydefinitions",
              "host": [
                "{{provider-connector-url}}"
              ],
              "path": [
                "management",
                "v3",
                "policydefinitions"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create usage policy",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{provider-connector-x-api-key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"@context\": [\r\n        \"https://w3id.org/catenax/2025/9/policy/odrl.jsonld\",\r\n        \"https://w3id.org/catenax/2025/9/policy/context.jsonld\",\r\n        {\r\n            \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\r\n        }\r\n    ],\r\n    \"@type\": \"PolicyDefinition\",\r\n    \"@id\": \"{{usage-policy}}\",\r\n    \"policy\": {\r\n        \"@type\": \"Set\",\r\n        \"permission\": [\r\n            {\r\n                \"action\": \"use\",\r\n                \"constraint\": {\r\n                    \"and\": [\r\n                        {\r\n                            \"leftOperand\": \"UsagePurpose\",\r\n                            \"operator\": \"isAnyOf\",\r\n                            \"rightOperand\": \"cx.core.industrycore:1\"\r\n                        },\r\n                        {\r\n                            \"leftOperand\": \"FrameworkAgreement\",\r\n                            \"operator\": \"eq\",\r\n                            \"rightOperand\": \"DataExchangeGovernance:1.0\"\r\n                        }\r\n                    ]\r\n                }\r\n            }\r\n        ]\r\n    }\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{provider-connector-url}}/management/v3/policydefinitions",
              "host": [
                "{{provider-connector-url}}"
              ],
              "path": [
                "management",
                "v3",
                "policydefinitions"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create contract definition",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{provider-connector-x-api-key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"@context\": {\r\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\r\n  },\r\n  \"@id\": \"{{contract-definition}}\",\r\n  \"@type\": \"ContractDefinition\",\r\n  \"accessPolicyId\": \"{{access-policy}}\",\r\n  \"contractPolicyId\": \"{{usage-policy}}\",\r\n  \"assetsSelector\": {\r\n    \"@type\": \"CriterionDto\",\r\n    \"operandLeft\": \"https://w3id.org/edc/v0.0.1/ns/id\",\r\n    \"operator\": \"=\",\r\n    \"operandRight\": \"{{asset-id}}\"\r\n  }\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{provider-connector-url}}/management/v3/contractdefinitions",
              "host": [
                "{{provider-connector-url}}"
              ],
              "path": [
                "management",
                "v3",
                "contractdefinitions"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Consumer",
      "item": [
        {
          "name": "Discovery",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{consumer-connector-x-api-key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"@context\": {\r\n        \"tx\": \"https://w3id.org/tractusx/v0.0.1/ns/\",\r\n        \"edc\": \"https://w3id.org/edc/v0.0.1/ns/\"\r\n    },\r\n    \"@type\": \"tx:ConnectorParamsDiscoveryRequest\",\r\n    \"tx:bpnl\": \"{{provider-connector-bpn}}\",\r\n    \"edc:counterPartyAddress\": \"{{provider-connector-dsp-url}}/api/v1/dsp\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{consumer-connector-url}}/management/v4alpha/connectordiscovery/dspversionparams",
              "host": [
                "{{consumer-connector-url}}"
              ],
              "path": [
                "management",
                "v4alpha",
                "connectordiscovery",
                "dspversionparams"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Catalog request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{consumer-connector-x-api-key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"@context\": {\r\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\",\r\n    \"odrl\": \"http://www.w3.org/ns/odrl/2/\"\r\n  },\r\n  \"@type\": \"CatalogRequest\",\r\n  \"counterPartyId\": \"{{provider-connector-bpn}}\",\r\n  \"counterPartyAddress\": \"{{provider-connector-dsp-url}}/api/v1/dsp\",\r\n  \"protocol\": \"{SUPPORTED_TYPE}\",\r\n  \"querySpec\": {\r\n    \"offset\": 0,\r\n    \"limit\": 50\r\n  }\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{consumer-connector-url}}/management/v3/catalog/request",
              "host": [
                "{{consumer-connector-url}}"
              ],
              "path": [
                "management",
                "v3",
                "catalog",
                "request"
              ]
            }
          },
          "response": []
        },
        {
          "name": "EDRs",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{consumer-connector-x-api-key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"@context\": [\r\n        \"https://w3id.org/catenax/2025/9/policy/odrl.jsonld\",\r\n        \"https://w3id.org/catenax/2025/9/policy/context.jsonld\",\r\n        {\r\n            \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\r\n        }\r\n    ],\r\n    \"@type\": \"ContractRequest\",\r\n    \"counterPartyAddress\": \"{{provider-connector-dsp-url}}/api/v1/dsp\",\r\n    \"protocol\": \"{SUPPORTED_TYPE}\",\r\n    \"policy\": {\r\n        \"@id\": \"{OFFER_ID}\",\r\n        \"@type\": \"Offer\",\r\n        \"assigner\": \"{{provider-connector-bpn}}\",\r\n        \"permission\": [\r\n            {\r\n                \"action\": \"use\",\r\n                \"constraint\": {\r\n                    \"and\": [\r\n                        {\r\n                            \"leftOperand\": \"UsagePurpose\",\r\n                            \"operator\": \"isAnyOf\",\r\n                            \"rightOperand\": \"cx.core.industrycore:1\"\r\n                        },\r\n                        {\r\n                            \"leftOperand\": \"FrameworkAgreement\",\r\n                            \"operator\": \"eq\",\r\n                            \"rightOperand\": \"DataExchangeGovernance:1.0\"\r\n                        }\r\n                    ]\r\n                }\r\n            }\r\n        ],\r\n        \"prohibition\": [],\r\n        \"obligation\": [],\r\n        \"target\": \"{{asset-id}}\"\r\n    },\r\n    \"callbackAddresses\": []\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{consumer-connector-url}}/management/v3/edrs",
              "host": [
                "{{consumer-connector-url}}"
              ],
              "path": [
                "management",
                "v3",
                "edrs"
              ]
            }
          },
          "response": []
        },
        {
          "name": "EDRs request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{consumer-connector-x-api-key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"@context\": {\r\n    \"@vocab\": \"https://w3id.org/edc/v0.0.1/ns/\"\r\n  },\r\n  \"@type\": \"QuerySpec\",\r\n  \"filterExpression\": [\r\n    {\r\n      \"operandLeft\": \"assetId\",\r\n      \"operator\": \"=\",\r\n      \"operandRight\": \"{{asset-id}}\"\r\n    }\r\n  ]\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{consumer-connector-url}}/management/v3/edrs/request",
              "host": [
                "{{consumer-connector-url}}"
              ],
              "path": [
                "management",
                "v3",
                "edrs",
                "request"
              ]
            }
          },
          "response": []
        },
